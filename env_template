# King Arthur Baking AI Assistant - Environment Variables
# Copy this file to .env and replace the placeholder values with your actual API keys

# ===== REQUIRED VARIABLES =====
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Get your MongoDB Atlas connection string from: https://cloud.mongodb.com/
# Format: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# ===== OPTIONAL VARIABLES =====
# Database configuration
MONGODB_DB_NAME=king_arthur_baking_db
MONGODB_COLLECTION_NAME=mixes

# Scraping configuration
SCRAPING_DELAY=1
MAX_RETRIES=3

# AI Agent configuration
TEMPERATURE=0.1
MAX_TOKENS=1000
CHUNK_SIZE=1000
CHUNK_OVERLAP=200 